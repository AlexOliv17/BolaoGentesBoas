# ─────────────────────────────────────────────
# Supabase — valores públicos
# Obtenha em: Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<seu-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ─────────────────────────────────────────────
# Supabase — SOMENTE SERVIDOR
# NUNCA prefixar com NEXT_PUBLIC_
# Obtenha em: Supabase Dashboard → Settings → API → service_role key
# ─────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─────────────────────────────────────────────
# Servidor SMTP — envio de e-mails (somente servidor)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.servidor.com
SMTP_PORT=465
SMTP_USER=email@servidor.com
SMTP_PASS=senha_app

# ─────────────────────────────────────────────
# football-data.org — API de futebol (somente servidor)
# Obtenha em: https://www.football-data.org/client/register
# ─────────────────────────────────────────────
FOOTBALL_DATA_API_KEY=<sua-chave>

# ─────────────────────────────────────────────
# Segredo para proteção das rotas de cron
# Gere com: openssl rand -hex 32
# ─────────────────────────────────────────────
CRON_SECRET=<segredo-gerado>
